{
  "title": "LLMOps — Microservices Overview",
  "uid": "llmops-overview",
  "tags": ["llmops", "microservices"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Requêtes / seconde par service",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum by (service) (rate(http_requests_total[1m]))",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Latence p95 par service (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "1000 * histogram_quantile(0.95, sum by (le, service) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{service}} p95"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Taux d'erreur (HTTP 5xx) par service",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum by (service) (rate(http_requests_total{status=~\"5..\"}[5m]))",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Services up",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "count(up{job!=\"prometheus\"} == 1)",
          "legendFormat": "Services up"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "none", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] } } }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Requêtes / min (total)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "60 * sum(rate(http_requests_total[5m]))",
          "legendFormat": "req/min"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 1 } }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Taux erreurs global (1h)",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"5..\"}[1h])) / sum(rate(http_requests_total[1h]))",
          "legendFormat": "error rate"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "decimals": 2, "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.01 }, { "color": "red", "value": 0.05 }] } } }
    },
    {
      "id": 7,
      "type": "row",
      "title": "Watcher — Live Traffic Monitoring",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "collapsed": false
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Watcher polls / minute par zone",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 17 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum by (zone, status) (rate(watcher_polls_total[5m])) * 60",
          "legendFormat": "{{zone}} · {{status}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 1 } }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Événements extraits / heure par sévérité",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 17 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "sum by (severity) (rate(watcher_events_extracted_total[15m])) * 3600",
          "legendFormat": "{{severity}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 1 } }
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Coût LLM total watcher (USD)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 25 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "sum(watcher_translation_cost_usd_total)", "legendFormat": "cost" }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 4 } }
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Tokens LLM total watcher",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 25 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "sum(watcher_translation_tokens_total)", "legendFormat": "tokens" }
      ],
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 0 } }
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Total événements extraits",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 25 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "sum(watcher_events_extracted_total)", "legendFormat": "events" }
      ],
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 0 } }
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Polls réussis / total",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 25 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "sum(watcher_polls_total{status=\"ok\"}) / sum(watcher_polls_total)", "legendFormat": "success rate" }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "decimals": 2 } }
    }
  ]
}
